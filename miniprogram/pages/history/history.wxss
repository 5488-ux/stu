page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.history-scroll {
  flex: 1;
  height: 0;
}

.history-page {
  padding: 20rpx 20rpx calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 18rpx;
  box-shadow: 0 8rpx 30rpx rgba(49, 71, 138, 0.08);
}

.history-main {
  flex: 1;
  min-width: 0;
}

.history-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-preview {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: var(--text-sub);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8b96ad;
}

.delete-btn {
  flex: none;
  border: 1px solid #ff6e6e;
  color: #ff4f4f;
  background: #fff;
}
