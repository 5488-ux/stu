page {
  height: 100vh;
  overflow: hidden;
}

.legal-page {
  height: 100vh;
  position: relative;
  box-sizing: border-box;
}

.legal-scroll {
  height: 100vh;
  padding: 20rpx 20rpx 300rpx;
  box-sizing: border-box;
}

.hero {
  padding: 20rpx 6rpx 10rpx;
}

.app-name {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 10rpx;
  color: var(--text-main);
  font-size: 40rpx;
  font-weight: 800;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: var(--text-sub);
  font-size: 26rpx;
  line-height: 1.6;
}

.legal-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 14rpx;
  box-sizing: border-box;
}

.doc-title {
  color: var(--text-main);
  font-size: 32rpx;
  font-weight: 800;
}

.date,
.intro {
  margin-top: 12rpx;
  color: var(--text-sub);
  font-size: 24rpx;
  line-height: 1.6;
}

.section {
  margin-top: 24rpx;
}

.section-title {
  color: var(--text-main);
  font-size: 28rpx;
  font-weight: 800;
}

.section-body {
  display: block;
  margin-top: 10rpx;
  color: #38445f;
  font-size: 25rpx;
  line-height: 1.75;
  white-space: pre-wrap;
}

.confirm-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 20rpx calc(34rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1px solid var(--border);
  box-shadow: 0 -8rpx 24rpx rgba(49, 71, 138, 0.08);
  box-sizing: border-box;
}

.agree-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--text-main);
  font-size: 24rpx;
  line-height: 1.5;
}

.buttons {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 16rpx;
  margin-top: 16rpx;
}

.primary,
.secondary {
  min-height: 78rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary {
  color: #fff;
  background: linear-gradient(135deg, #2468ff 0%, #46a1ff 100%);
}

.primary[disabled] {
  color: rgba(255, 255, 255, 0.8);
  background: #b9c5da;
}

.secondary {
  color: var(--text-sub);
  background: #f6f8fc;
  border: 1px solid var(--border);
}
