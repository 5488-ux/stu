.chat-page,
page {
  min-height: 0;
}

page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-page {
  position: relative;
  flex: 1;
  height: auto;
  padding: 96rpx 16rpx calc(12rpx + env(safe-area-inset-bottom));
  gap: 14rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.settings-icon {
  position: absolute;
  top: 14rpx;
  right: 18rpx;
  z-index: 5;
  width: 68rpx;
  height: 68rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #ffffff;
  color: var(--primary);
  border: 1px solid var(--border);
  box-shadow: 0 8rpx 22rpx rgba(49, 71, 138, 0.12);
}

.settings-icon::after {
  border: none;
}

.settings-line {
  position: relative;
  width: 34rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: var(--primary);
}

.settings-line::after {
  content: "";
  position: absolute;
  top: -5rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 3rpx solid var(--primary);
  box-sizing: border-box;
}

.line-one::after {
  left: 4rpx;
}

.line-two::after {
  right: 4rpx;
}

.line-three::after {
  left: 14rpx;
}

.messages {
  flex: 1;
  height: 0;
  min-height: 0;
  padding: 8rpx 6rpx 12rpx;
  box-sizing: border-box;
}

.scroll-anchor {
  height: 1rpx;
}

.msg-row {
  display: flex;
  margin: 14rpx 0;
}

.msg-left {
  justify-content: flex-start;
}

.msg-right {
  justify-content: flex-end;
}

.bubble {
  max-width: 88%;
  min-height: 0;
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
  box-sizing: border-box;
}

.bubble.assistant {
  background: #ffffff;
  border: 1px solid var(--border);
  color: #1c2742;
}

.bubble.user {
  color: #fff;
  background: linear-gradient(135deg, #2468ff 0%, #4fa9ff 100%);
}

.bubble rich-text {
  display: block;
  width: 100%;
}

.code-card {
  margin: 10rpx 0;
  overflow: hidden;
  border: 1px solid #dfe7f5;
  border-radius: 12rpx;
  background: #f7f9fd;
}

.code-toolbar {
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 8rpx 12rpx;
  border-bottom: 1px solid #dfe7f5;
  background: #ffffff;
  box-sizing: border-box;
}

.code-lang {
  color: var(--text-sub);
  font-size: 22rpx;
  font-weight: 700;
}

.code-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.code-action {
  min-width: 66rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.code-scroll {
  max-width: 100%;
  padding: 14rpx;
  box-sizing: border-box;
}

.code-text {
  font-family: monospace;
  font-size: 24rpx;
  line-height: 1.55;
  white-space: pre;
  color: #26334f;
}

.bottom-jump {
  position: absolute;
  left: 50%;
  bottom: calc(260rpx + env(safe-area-inset-bottom));
  z-index: 6;
  width: 64rpx;
  height: 64rpx;
  min-width: 64rpx;
  max-width: 64rpx;
  min-height: 64rpx;
  max-height: 64rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid var(--border);
  box-shadow: 0 10rpx 26rpx rgba(49, 71, 138, 0.18);
  box-sizing: border-box;
}

.bottom-arrow {
  width: 18rpx;
  height: 18rpx;
  border-right: 5rpx solid var(--primary);
  border-bottom: 5rpx solid var(--primary);
  transform: rotate(45deg) translateY(-3rpx);
  border-radius: 2rpx;
}

.composer {
  width: 100%;
  box-sizing: border-box;
  flex: none;
  padding: 16rpx;
}

.topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

.session-picker {
  max-width: 320rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.model-picker {
  display: block;
  margin-bottom: 12rpx;
}

.model {
  font-size: 22rpx;
  color: var(--text-sub);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.web-search-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.learning-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #eefbf5;
  border: 1px solid #d6f3e3;
}

.learning-label {
  color: #12805c;
  font-size: 23rpx;
  font-weight: 800;
}

.learning-toggle {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #12805c;
  font-size: 22rpx;
  font-weight: 900;
}

.learning-toggle.active {
  color: #ffffff;
  background: #16a34a;
}

.web-search-label {
  color: var(--text-sub);
  font-size: 24rpx;
  font-weight: 700;
}

.multimodal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 0 0 12rpx;
}

.mm-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f2f6ff;
  border: 1px solid #dce8ff;
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 800;
}

.mm-pill.active {
  color: #fff;
  background: linear-gradient(135deg, #2468ff 0%, #46a1ff 100%);
  border-color: transparent;
  box-shadow: 0 8rpx 18rpx rgba(36, 104, 255, 0.18);
}

.mm-pill.ghost {
  background: #fff;
  color: #52627a;
}

.image-size-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin: -2rpx 0 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #f7faff;
  border: 1px solid #e3ecfb;
}

.image-size-label {
  color: var(--text-sub);
  font-size: 23rpx;
  font-weight: 700;
}

.image-size-picker {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 800;
}

.attachment-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.attachment-chip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #fff8eb;
  color: #7a4e00;
  font-size: 22rpx;
  font-weight: 700;
}

.attachment-remove {
  flex: none;
  width: 34rpx;
  height: 34rpx;
  line-height: 32rpx;
  border-radius: 50%;
  text-align: center;
  background: rgba(122, 78, 0, 0.12);
}

.vision-templates {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: -2rpx 0 12rpx;
}

.vision-template {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eefbf5;
  color: #12805c;
  font-size: 22rpx;
  font-weight: 800;
}


.actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.action-link {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 700;
  flex: none;
}

.action-link.disabled {
  opacity: 0.5;
}

.input {
  width: 100%;
  min-height: 92rpx;
  max-height: 260rpx;
  background: #f9fbff;
  border: 1px solid var(--border);
  border-radius: 14rpx;
  padding: 14rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}
